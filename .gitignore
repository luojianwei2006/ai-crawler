# ---- PHP / Laravel (scaffold/backend) ----
scaffold/backend/vendor/
scaffold/backend/node_modules/
scaffold/backend/.env
scaffold/backend/.env.backup
scaffold/backend/.env.production
scaffold/backend/phpunit.xml
scaffold/backend/.phpunit.result.cache
scaffold/backend/storage/*.key
scaffold/backend/storage/pail
scaffold/backend/bootstrap/cache/*.php
scaffold/backend/public/build
scaffold/backend/public/hot
scaffold/backend/public/storage

# ---- Node / Vite (scaffold/frontend) ----
scaffold/frontend/node_modules/
scaffold/frontend/dist/
scaffold/frontend/.env
scaffold/frontend/.env.*
scaffold/frontend/*.local

# ---- OS / Editor ----
.DS_Store
Thumbs.db
*.log
.idea/
.vscode/
*.swp

# ---- Uploads / runtime artifacts (keep template.zip, ignore user uploads) ----
scaffold/backend/storage/app/plugins/*
!scaffold/backend/storage/app/plugins/.gitignore
