APP_NAME="AI Crawler Plugin Platform"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=ai_crawler
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file

# ---- 模型供应商默认值（管理员仍可在后台增删改，密钥 AES-256 入库）----
# 智谱 GLM（OpenAI 兼容）
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_API_KEY=
GLM_MODEL=glm-4-plus
# DeepSeek（OpenAI 兼容）
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
# OpenAI / GPT（OpenAI 兼容）
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ---- 子进程沙箱（见 PRD §8 / tasks M5）----
SANDBOX_PHP_BINARY=/usr/local/bin/php
SANDBOX_MEMORY_LIMIT=256M
SANDBOX_TIMEOUT=300
# 危险函数白名单式禁用（插件子进程内）
SANDBOX_DISABLE_FUNCTIONS=exec,shell_exec,system,passthru,popen,proc_open,pcntl_*,posix_*

# ---- 合规底线（见 PRD §9 / report §六）----
COMPLIANCE_ROBOTS_ENFORCED=true
COMPLIANCE_MAX_DEPTH=3
